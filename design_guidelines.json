{
  "project_name": "Livrella (EssentiElles)",
  "domain": "Health, Wellness, Baby Products, E-commerce",
  "theme": "Light",
  "archetype": "Organic & Earthy / Pastel & Soft Hybrid",
  "instructions_to_main_agent": [
    "Strictly use React Native components (View, Text, Image, ScrollView, TouchableOpacity, etc.). NO web libraries like Tailwind, HTML, div, span, or className.",
    "Use StyleSheet.create() for all styling logic.",
    "Utilize 'expo-router' for navigation: Stack for Auth/Onboarding, Tabs for Main App.",
    "Build a bilingual system (FR/EN). Create a centralized translation/dictionary module.",
    "Implement minimum 48dp touch targets for accessibility on all interactive elements.",
    "Add 'data-testid' to ALL interactive elements (buttons, inputs, cards, toggles) using kebab-case role-based names.",
    "For components, focus on rounded corners (borderRadius: 16 to 24), soft shadows (elevation for Android, shadow props for iOS), and generous padding (16px to 24px).",
    "DO NOT use placeholder image URLs (like via.placeholder.com). Use the media URLs provided in this file exclusively."
  ],
  "colors": {
    "brand": {
      "primary": "#B5838D",
      "primary_light": "#E5B8BE",
      "primary_dark": "#9D6B75",
      "secondary": "#FFCAD4",
      "accent": "#F4ECE6"
    },
    "background": {
      "default": "#FDFBF9",
      "card": "#FFFFFF",
      "modal_overlay": "rgba(43, 45, 66, 0.4)"
    },
    "text": {
      "primary": "#2B2D42",
      "secondary": "#6D6875",
      "tertiary": "#A09CAB",
      "inverse": "#FFFFFF"
    },
    "feedback": {
      "success": "#84A59D",
      "success_bg": "#E9F2EF",
      "error": "#F28482",
      "error_bg": "#FDF0EF",
      "warning": "#F4A261"
    },
    "borders": {
      "light": "#F0EBE6",
      "medium": "#E0D7D3"
    }
  },
  "typography": {
    "font_family": "Poppins",
    "weights": {
      "light": "300",
      "regular": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "scales": {
      "h1": { "fontSize": 32, "lineHeight": 40, "fontWeight": "700", "color": "#2B2D42", "letterSpacing": -0.5 },
      "h2": { "fontSize": 24, "lineHeight": 32, "fontWeight": "600", "color": "#2B2D42", "letterSpacing": -0.3 },
      "h3": { "fontSize": 20, "lineHeight": 28, "fontWeight": "600", "color": "#2B2D42" },
      "body_large": { "fontSize": 18, "lineHeight": 26, "fontWeight": "400", "color": "#6D6875" },
      "body": { "fontSize": 16, "lineHeight": 24, "fontWeight": "400", "color": "#6D6875" },
      "body_small": { "fontSize": 14, "lineHeight": 20, "fontWeight": "400", "color": "#6D6875" },
      "caption": { "fontSize": 12, "lineHeight": 16, "fontWeight": "500", "color": "#A09CAB", "textTransform": "uppercase", "letterSpacing": 0.5 },
      "button": { "fontSize": 16, "lineHeight": 24, "fontWeight": "600" }
    }
  },
  "spacing_and_layout": {
    "base": 4,
    "scale": {
      "xs": 4,
      "sm": 8,
      "md": 16,
      "lg": 24,
      "xl": 32,
      "xxl": 48,
      "xxxl": 64
    },
    "screen_padding": 24,
    "border_radius": {
      "sm": 8,
      "md": 16,
      "lg": 24,
      "pill": 9999
    },
    "shadows": {
      "card": {
        "ios": { "shadowColor": "#2B2D42", "shadowOffset": { "width": 0, "height": 4 }, "shadowOpacity": 0.05, "shadowRadius": 12 },
        "android": { "elevation": 3 }
      },
      "button": {
        "ios": { "shadowColor": "#B5838D", "shadowOffset": { "width": 0, "height": 4 }, "shadowOpacity": 0.2, "shadowRadius": 8 },
        "android": { "elevation": 4 }
      }
    }
  },
  "components": {
    "button": {
      "primary": {
        "backgroundColor": "#B5838D",
        "borderRadius": 24,
        "paddingVertical": 16,
        "paddingHorizontal": 24,
        "minHeight": 56,
        "alignItems": "center",
        "justifyContent": "center"
      },
      "secondary": {
        "backgroundColor": "#FFCAD4",
        "borderRadius": 24,
        "paddingVertical": 16,
        "paddingHorizontal": 24,
        "minHeight": 56,
        "alignItems": "center",
        "justifyContent": "center"
      },
      "outline": {
        "backgroundColor": "transparent",
        "borderWidth": 1.5,
        "borderColor": "#B5838D",
        "borderRadius": 24,
        "paddingVertical": 16,
        "paddingHorizontal": 24,
        "minHeight": 56,
        "alignItems": "center",
        "justifyContent": "center"
      }
    },
    "card": {
      "container": {
        "backgroundColor": "#FFFFFF",
        "borderRadius": 16,
        "padding": 16,
        "marginVertical": 8
      }
    },
    "input": {
      "container": {
        "backgroundColor": "#FFFFFF",
        "borderWidth": 1,
        "borderColor": "#F0EBE6",
        "borderRadius": 12,
        "paddingHorizontal": 16,
        "minHeight": 56,
        "flexDirection": "row",
        "alignItems": "center",
        "marginVertical": 8
      },
      "focused": {
        "borderColor": "#B5838D",
        "borderWidth": 1.5
      }
    },
    "bottom_tab_bar": {
      "backgroundColor": "#FFFFFF",
      "borderTopWidth": 1,
      "borderTopColor": "#F0EBE6",
      "height": 70,
      "paddingBottom": 10,
      "paddingTop": 10
    }
  },
  "accessibility_and_testing": {
    "touch_targets": "Ensure minHeight and minWidth of 48 for all Touchables.",
    "contrast": "Text over backgrounds must have a minimum ratio of 4.5:1.",
    "test_ids_examples": [
      "login-submit-button",
      "email-input",
      "home-delivery-card",
      "product-add-to-cart-button",
      "tab-home",
      "tab-profile"
    ]
  },
