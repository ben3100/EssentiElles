# API Configuration
# For local development with Docker Compose backend
EXPO_PUBLIC_BACKEND_URL=http://localhost:8000

# Alternative: For development on physical device
# Replace with your computer's local IP address
# EXPO_PUBLIC_BACKEND_URL=http://192.168.1.XXX:8000

# For production deployment
# EXPO_PUBLIC_BACKEND_URL=https://api.livrella.com

# API Settings
API_TIMEOUT=30000

# Features
ENABLE_ANALYTICS=false
ENABLE_PUSH_NOTIFICATIONS=false

# Stripe (Add when ready)
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
